# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
# Optional: comma-separated hosts for production (e.g. yourdomain.com,www.yourdomain.com)
# DJANGO_ALLOWED_HOSTS=

# Use SQLite instead of PostgreSQL (set to true for local dev without Postgres)
# FORCE_SQLITE=true

# Email (e.g. Gmail SMTP)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL="Your App <your-email@gmail.com>"

# Google OAuth (optional – used for Login with Google, Calendar, and Drive)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/accounts/google/login/callback/

# Cloudinary media storage (optional – when set, avatars, covers, and post images go to Cloudinary)
# Get these from https://console.cloudinary.com/ (Dashboard)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Google Drive media storage (optional – used only if CLOUDINARY_* is not set)
# DRIVE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# DRIVE_MEDIA_FOLDER_ID=your-drive-folder-id

# PostgreSQL (used when FORCE_SQLITE is not true)
DB_NAME=postgres
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
